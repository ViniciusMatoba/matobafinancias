rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{uid}/entries/{txId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /cards/{uid}/list/{cardId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /config/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Carteiras — coleção flat filtrada por userId
    match /wallets/{walletId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
    }

    // Metas/caixinhas — coleção flat filtrada por userId
    match /goals/{goalId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
    }

    // Perfil do usuário — fcmToken e telegramChatId são sensíveis
    match /users/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Códigos temporários de vinculação Telegram (expiram em 15 min)
    match /telegramLinks/{code} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
      allow read, update: if false; // somente Cloud Functions (admin SDK) lê e atualiza
    }
  }
}

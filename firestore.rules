rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{uid}/entries/{txId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /cards/{uid}/list/{cardId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /config/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Perfil público + token FCM (escrito pelo próprio usuário após solicitar permissão)
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Códigos temporários de vinculação Telegram (expiram em 15 min)
    // Usuário cria para si mesmo; leitura/exclusão feita pelas Cloud Functions (admin SDK)
    match /telegramLinks/{code} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow read, delete: if false; // somente Cloud Functions (admin SDK) lê e apaga
    }
  }
}
